# Copy to .env for local runs.
OPENROUTER_API_KEY=
HYDRA_DB_API_KEY=

# Optional fallback/dev provider.
GROQ_API_KEY=

# Defaults used for the improved scored path.
MODEL=openrouter/meta-llama/llama-3.3-70b-instruct
APPWORLD_EXPERIMENT=team_plutogen
APPWORLD_DATASET=agent_arena_eval
MAX_TASKS=0
MAX_INTERACTIONS=40
PLAYBOOK_ROUTER=1
SELF_VERIFY=0
COMPLETE_GUARD=1
PLAYBOOK_SCOPE=high_risk
INJECT_DEMOS=1
